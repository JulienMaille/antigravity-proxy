{
  "name": "antigravity-proxy",
  "version": "1.0.0",
  "description": "Proxy translating Antigravity Google API calls to any LLM provider",
  "type": "module",
  "main": "src/index.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "start:prod": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx test/run.ts",
    "gen-certs": "node scripts/gen-certs.mjs"
  },
  "dependencies": {
    "ai": "^6.0.193",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "hpagent": "^1.2.0",
    "node-forge": "^1.4.0",
    "socks-proxy-agent": "^8.0.5",
    "undici": "^7.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0"
  }
}
