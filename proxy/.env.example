# ─── Provider priority ────────────────────────────────────────────────────────
# Comma-separated list, first = primary. The router tries providers left-to-right.
PROVIDER_PRIORITY=opencode,nvidia,google,openrouter,groq
PROVIDER=opencode

# ─── API Keys ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
NVIDIA_API_KEY=nvapi-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
OPENCODE_API_KEY=public

# ─── Ports ────────────────────────────────────────────────────────────────────
PROXY_PORT=443    # TLS port Antigravity connects to. Use 8443 if you can't bind 443.
API_PORT=4000     # Dashboard + REST API (HTTP)

# ─── Retry & failover ─────────────────────────────────────────────────────────
PROXY_RETRIES=3           # Attempts per provider before failover
PROXY_BACKOFF_MS=100      # Initial backoff ms (doubles each retry)

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info            # debug | info | warn | error
LOG_MAX_SIZE_MB=10        # Rotate log file at this size (MB)
LOG_MAX_FILES=5           # Keep this many rotated log files
LOG_MAX_AGE_DAYS=30       # Delete logs older than this many days

# ─── Rate limiting (0 = unlimited) ────────────────────────────────────────────
RATE_LIMIT_GLOBAL=0
RATE_LIMIT_PROVIDER=0
RATE_LIMIT_WINDOW_MS=60000

# ─── Dashboard auth (optional) ────────────────────────────────────────────────
# Can also be set from the Config tab in the dashboard.
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=your_password

# ─── Failover webhook (optional) ──────────────────────────────────────────────
# POST payload sent whenever the router falls back to a backup provider.
# FAILOVER_WEBHOOK_URL=https://hooks.example.com/webhook

# ─── Workspace context hardening (optional) ───────────────────────────────────
# Controls how the proxy wraps agent-context.md to prevent context-confusion.
# off = pass through as-is  |  loose = lightweight note  |  strict = full envelope (default)
# WORKSPACE_CONTEXT_ENVELOPE=strict

# ─── Inline context stripping (optional) ──────────────────────────────────────
# strip       = remove skills/plugins/identity, inject compact agent-context.md (~3500 tokens saved per request)
# passthrough = send full Antigravity context to the model unchanged (debugging)
CONTEXT_STRIP_MODE=strip

# ─── Advanced ─────────────────────────────────────────────────────────────────
# Override the absolute path to agent-context.md (defaults to ../../agent-context.md from proxy/)
# AGENT_CONTEXT_PATH=/path/to/agent-context.md

# Override Google backend IP (skips DNS resolution; useful if DNS is flaky)
# GOOGLE_BACKEND_IP=216.58.214.74
